<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>SwiftNZB</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>de</string>
	</array>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Live Activity (download progress on Lock Screen + Dynamic Island). -->
	<key>NSSupportsLiveActivities</key>
	<true/>

	<!-- Background execution: a single opportunistic BGProcessingTask (see BackgroundTaskService).
	     iOS cannot sustain raw-socket NNTP downloads while suspended; this only nudges the queue
	     and persists resume state when the system grants time. Declare only what we use. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>de.valentinlehmann.swiftnzb.processing</string>
	</array>

	<!-- Completed downloads live in the app's Documents container and appear in the Files app. -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- NZB files (XML). Claim the type for Open-in / share sheet and declare the UTI. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>NZB File</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>de.valentinlehmann.swiftnzb.nzb</string>
			</array>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
		</dict>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>de.valentinlehmann.swiftnzb.nzb</string>
			<key>UTTypeDescription</key>
			<string>NZB File</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.xml</string>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>nzb</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/x-nzb</string>
				</array>
			</dict>
		</dict>
	</array>

	<!-- No App Transport Security exception is declared. ATS governs the URL Loading System
	     (URLSession/CFNetwork); this app performs no such requests. All Usenet traffic uses
	     Network.framework (NWConnection), which ATS does not police, so plain-NNTP and self-signed
	     TLS servers already work — and omitting a global exception avoids unnecessary review
	     scrutiny. Re-add a scoped exception only if HTTP URL loading is ever introduced. -->

	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>de.valentinlehmann.swiftnzb</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>swiftnzb</string>
			</array>
		</dict>
	</array>

	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
